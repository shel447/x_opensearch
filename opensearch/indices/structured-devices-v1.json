{
  "settings": {
    "index": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "max_ngram_diff": 30
    },
    "analysis": {
      "char_filter": {
        "mac_separator_strip": {
          "type": "pattern_replace",
          "pattern": "(?i)(?<=[0-9a-f])[:.-](?=[0-9a-f])",
          "replacement": ""
        }
      },
      "normalizer": {
        "lowercase_norm": {
          "type": "custom",
          "filter": ["lowercase"]
        },
        "mac_norm": {
          "type": "custom",
          "char_filter": ["mac_separator_strip"],
          "filter": ["lowercase"]
        }
      },
      "tokenizer": {
        "net_tokenizer": {
          "type": "pattern",
          "pattern": "[^A-Za-z0-9_.:-]+"
        }
      },
      "filter": {
        "net_ngram_filter": {
          "type": "ngram",
          "min_gram": 2,
          "max_gram": 32,
          "preserve_original": true
        }
      },
      "analyzer": {
        "net_text": {
          "type": "custom",
          "tokenizer": "net_tokenizer",
          "filter": ["lowercase"]
        },
        "mac_flat": {
          "type": "custom",
          "char_filter": ["mac_separator_strip"],
          "tokenizer": "net_tokenizer",
          "filter": ["lowercase"]
        },
        "net_ngram": {
          "type": "custom",
          "tokenizer": "net_tokenizer",
          "filter": ["lowercase", "net_ngram_filter"]
        }
      }
    }
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "device_id": {
        "type": "keyword",
        "normalizer": "lowercase_norm"
      },
      "device_type": {
        "type": "keyword",
        "normalizer": "lowercase_norm"
      },
      "name": {
        "type": "text",
        "analyzer": "net_text",
        "fields": {
          "keyword": {
            "type": "keyword",
            "normalizer": "lowercase_norm",
            "ignore_above": 512
          },
          "wild": {
            "type": "wildcard"
          },
          "ngram": {
            "type": "text",
            "analyzer": "net_ngram",
            "search_analyzer": "net_text"
          }
        }
      },
      "ip_address": {
        "type": "ip"
      },
      "ip_keyword": {
        "type": "keyword",
        "normalizer": "lowercase_norm",
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "net_text"
          },
          "wild": {
            "type": "wildcard"
          },
          "ngram": {
            "type": "text",
            "analyzer": "net_ngram",
            "search_analyzer": "net_text"
          }
        }
      },
      "mac": {
        "type": "keyword",
        "normalizer": "mac_norm",
        "fields": {
          "raw": {
            "type": "keyword",
            "normalizer": "lowercase_norm",
            "ignore_above": 256
          },
          "text": {
            "type": "text",
            "analyzer": "net_text"
          },
          "mac": {
            "type": "text",
            "analyzer": "mac_flat"
          },
          "wild": {
            "type": "wildcard"
          }
        }
      },
      "vendor": {
        "type": "keyword",
        "normalizer": "lowercase_norm",
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "net_text"
          },
          "wild": {
            "type": "wildcard"
          }
        }
      },
      "status": {
        "type": "keyword",
        "normalizer": "lowercase_norm"
      },
      "port_count": {
        "type": "integer"
      },
      "last_seen": {
        "type": "date"
      },
      "attributes": {
        "type": "keyword",
        "normalizer": "lowercase_norm",
        "ignore_above": 32766,
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "net_text"
          },
          "mac": {
            "type": "text",
            "analyzer": "mac_flat"
          },
          "wild": {
            "type": "wildcard"
          },
          "ngram": {
            "type": "text",
            "analyzer": "net_ngram",
            "search_analyzer": "net_text"
          }
        }
      },
      "description": {
        "type": "text",
        "analyzer": "net_text",
        "term_vector": "with_positions_offsets",
        "fields": {
          "keyword": {
            "type": "keyword",
            "normalizer": "lowercase_norm",
            "ignore_above": 32766
          },
          "mac": {
            "type": "text",
            "analyzer": "mac_flat"
          },
          "wild": {
            "type": "wildcard"
          },
          "ngram": {
            "type": "text",
            "analyzer": "net_ngram",
            "search_analyzer": "net_text"
          }
        }
      }
    }
  }
}
